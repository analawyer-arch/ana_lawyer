# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=

# API-ключ Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Контакт специалиста отдела кадров (имя, Telegram, email и т. д.)
HR_CONTACT=

# Прокси для подключения к Telegram (если заблокирован в сети)
# Формат: http://user:pass@host:port  или  socks5://user:pass@host:port
# Оставьте пустым, если прокси не нужен
PROXY=
